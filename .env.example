# ElevenLabs (https://elevenlabs.io) — Conversational AI agent
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# Twilio (https://twilio.com) — account credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ngrok (https://ngrok.com) — used to expose the local server when WITH_NGROK=true
NGROK_AUTHTOKEN=

# Call redirection — used by the `redirect_call` client tool
# REDIRECT_COUNTRY_CODE is prepended to REDIRECT_TO_PHONE_NUMBER (e.g. +48)
REDIRECT_COUNTRY_CODE=+48
REDIRECT_TO_PHONE_NUMBER=
